// --- PEDIDOS Y DELIVERY ---


enum TipoPedido {
  LOCAL
  DELIVERY
  RETIRO
}

enum EstadoPedido {
  PENDIENTE
  EN_CAMINO
  ENTREGADO
  CANCELADO
}

enum MetodoPago {
  EFECTIVO
  TRANSFERENCIA
  TARJETA
}

model Pedido {
  id                String       @id @default(uuid())
  tipo              TipoPedido   @default(LOCAL)
  estado            EstadoPedido @default(PENDIENTE)
  total             Float        @default(0)
  
  nombreCliente     String?
  numeroCliente     String?
  metodoPago        MetodoPago?

  direccion         String?
  motivoCancelacion String?
  canceladoPor      Role?

  repartidorId      String?
  repartidor        User?        @relation("RepartidorPedidos", fields: [repartidorId], references: [id])

  detalles          PedidoDetalle[]
  createdAt         DateTime     @default(now())
}

model PedidoDetalle {
  id         String   @id @default(uuid())
  pedidoId   String
  productoId String
  cantidad   Int
  aderezos   Aderezo[]
  
  // ✅ PRECIO EDITABLE: El que se pone en el POS (ej: precio amigo)
  precioUnitario Float @default(0)
  
  // ✅ EXTRAS: Guardamos qué extras se eligieron en este producto
  // Guardamos un JSON para saber cuáles fueron gratis y cuáles se cobraron
  // Formato: [{id: "uuid", nombre: "Panceta", precio: 500, cobrado: true}]
  extras     Json?    

  subtotal   Float    // (precioUnitario * cantidad) + sumatoria de extras cobrados
  notas      String?  

  pedido     Pedido   @relation(fields: [pedidoId], references: [id])
  producto   Producto @relation(fields: [productoId], references: [id])

}

// --- GESTIÓN DE EXTRAS ---

model Extra {
  id          String   @id @default(uuid())
  nombre      String   @unique
  precio      Float    @default(500)   // precio por unidadMedida
  unidadMedida String  @default("un")  // un | sobre | ml | gr | etc
  stockActual Float    @default(0)
  activo      Boolean  @default(true)
  categoria   String   @default("ADEREZOS")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Aderezo {
  id     String @id @default(uuid())
  nombre String @unique
  detalles PedidoDetalle[]
}