// Configuración básica
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- AUTENTICACIÓN Y ROLES ---

enum Role {
  ADMIN       // Gestiona stock, recetas y usuarios
  TRABAJADOR  // Atiende local y cocina
  DELIVERY    // Solo ve pedidos para repartir
  CLIENTE     // (Opcional) para ver menú o estado
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  nombre    String
  role      Role     @default(TRABAJADOR)
  pedidos   Pedido[] @relation("RepartidorPedidos") // Para el rol DELIVERY
  createdAt DateTime @default(now())
}

// --- GESTIÓN DE STOCK (INSUMOS) ---

model Insumo {
  id           String           @id @default(uuid())
  nombre       String
  stockActual  Float            @default(0)
  stockMinimo  Float            @default(5)
  unidadMedida String
  recetas      ProductoReceta[]
  activo       Boolean          @default(true)

  // ✅ NUEVO: proveedor opcional
  proveedorId  String?
  proveedor    Proveedor?       @relation(fields: [proveedorId], references: [id])

  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model Proveedor {
  id        String   @id @default(uuid())
  nombre    String   @unique
  telefono  String?
  email     String?
  notas     String?
  activo    Boolean  @default(true)

  // ✅ un proveedor tiene muchos insumos
  insumos   Insumo[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- CATEGORIAS DE LOS PRODUCTOS ---
model Categoria {
  id          String    @id @default(uuid())
  nombre      String    @unique
  descripcion String?
  activo      Boolean   @default(true)
  productos   Producto[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// --- PRODUCTOS Y RECETAS DINÁMICAS ---

model Producto {
  id          String            @id @default(uuid())
  nombre      String            // Ej: "Hamburguesa Cuádruple"
  precio      Float
  esParaVenta Boolean           @default(true)
  activo      Boolean           @default(true)
  descripcion           String?
  codigo                String?  @unique
  tiempoPreparacionMin  Int?
  categoriaId String?
  categoria   Categoria? @relation(fields: [categoriaId], references: [id])
  receta      ProductoReceta[]
  detalles    PedidoDetalle[]
}

// Tabla intermedia para la "Receta" (Escandallo)
model ProductoReceta {
  id          String   @id @default(uuid())
  productoId  String
  insumoId    String
  cantidad    Float    // Ej: 4 (para 4 medallones)
  
  producto    Producto @relation(fields: [productoId], references: [id])
  insumo      Insumo   @relation(fields: [insumoId], references: [id])
}

