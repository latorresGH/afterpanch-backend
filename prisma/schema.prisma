// --- PEDIDOS Y DELIVERY ---


enum TipoPedido {
  LOCAL
  DELIVERY
  RETIRO
}

enum EstadoPedido {
  PENDIENTE
  EN_CAMINO
  ENTREGADO
  CANCELADO
}

enum MetodoPago {
  EFECTIVO
  TRANSFERENCIA
  TARJETA
}

model Pedido {
  id                String          @id @default(uuid())
  tipo              TipoPedido      @default(LOCAL)
  estado            EstadoPedido    @default(PENDIENTE)
  total             Float           @default(0)

  nombreCliente     String?
  numeroCliente     String?
  metodoPago        MetodoPago?

  direccion         String?
  motivoCancelacion String?
  canceladoPor      Role?

  repartidorId      String?
  repartidor        User?           @relation("RepartidorPedidos", fields: [repartidorId], references: [id])

  detalles          PedidoDetalle[]
  ofertasAplicadas  PedidoOferta[]
  createdAt         DateTime        @default(now())
}

model PedidoDetalle {
  id            String        @id @default(uuid())
  pedidoId      String
  productoId    String
  cantidad      Int
  aderezos      Aderezo[]

  precioUnitario Float       @default(0)

  extras        Json?

  subtotal      Float
  notas         String?

  pedido        Pedido       @relation(fields: [pedidoId], references: [id])
  producto      Producto     @relation(fields: [productoId], references: [id])
  ofertaAplicada PedidoOferta[]
}

// --- GESTIÓN DE EXTRAS ---

model Extra {
  id          String   @id @default(uuid())
  nombre      String   @unique
  precio      Float    @default(500)   // precio por unidadMedida
  unidadMedida String  @default("un")  // un | sobre | ml | gr | etc
  stockActual Float    @default(0)
  activo      Boolean  @default(true)
  categoria   String   @default("ADEREZOS")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Aderezo {
  id        String          @id @default(uuid())
  nombre    String          @unique
  detalles  PedidoDetalle[]
}

// ============================================
// SISTEMA DE OFERTAS
// ============================================

enum TipoOferta {
  DOS_POR_UNO
  COMBO
  DESCUENTO_PORCENTAJE
  DESCUENTO_MONTO_FIJO
}

enum EstadoOferta {
  ACTIVA
  PAUSADA
  VENCIDA
}

model Oferta {
  id                  String          @id @default(uuid())
  nombre              String
  descripcion         String?
  tipo                TipoOferta
  estado              EstadoOferta    @default(ACTIVA)

  fechaInicio         DateTime
  fechaFin            DateTime?
  activa              Boolean         @default(true)

  porcentajeDescuento Float?
  montoDescuento      Float?

  maxUsosPorCliente   Int?
  maxUsosTotales      Int?
  usosActuales        Int             @default(0)

  diasAplicables      String          @default("1,2,3,4,5,6,7")
  horaInicio          String?
  horaFin             String?

  aplicaPorLinea      Boolean         @default(true)

  productos           OfertaProducto[]
  gruposCombo         GrupoCombo[]
  pedidosAplicados    PedidoOferta[]

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([activa, estado])
  @@index([fechaInicio, fechaFin])
}

model OfertaProducto {
  id            String    @id @default(uuid())
  ofertaId      String
  productoId    String
  obligatorio   Boolean   @default(false)
  cantidadMin   Int       @default(1)
  cantidadMax   Int?
  precioEspecial Float?

  oferta        Oferta    @relation(fields: [ofertaId], references: [id], onDelete: Cascade)
  producto      Producto  @relation(fields: [productoId], references: [id])

  @@unique([ofertaId, productoId])
}

model GrupoCombo {
  id            String        @id @default(uuid())
  ofertaId      String
  nombre        String
  obligatorio   Boolean       @default(true)
  cantidad      Int           @default(1)

  oferta        Oferta        @relation(fields: [ofertaId], references: [id], onDelete: Cascade)
  opciones      GrupoOpcion[]
}

model GrupoOpcion {
  id            String      @id @default(uuid())
  grupoComboId  String
  productoId    String

  grupoCombo    GrupoCombo  @relation(fields: [grupoComboId], references: [id], onDelete: Cascade)
  producto      Producto    @relation(fields: [productoId], references: [id])

  @@unique([grupoComboId, productoId])
}

model PedidoOferta {
  id                String        @id @default(uuid())
  pedidoId          String
  ofertaId          String
  pedidoDetalleId   String?       @unique

  precioOriginal    Float
  precioFinal       Float
  descuentoAplicado Float

  pedido            Pedido        @relation(fields: [pedidoId], references: [id])
  oferta            Oferta        @relation(fields: [ofertaId], references: [id])
  pedidoDetalle     PedidoDetalle? @relation(fields: [pedidoDetalleId], references: [id])

  @@index([pedidoId])
  @@index([ofertaId])
}