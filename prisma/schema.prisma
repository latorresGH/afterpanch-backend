// --- PEDIDOS Y DELIVERY ---


enum TipoPedido {
  LOCAL
  DELIVERY
  RETIRO
}

enum EstadoPedido {
  PENDIENTE
  EN_CAMINO
  ENTREGADO
  CANCELADO
}

enum MetodoPago {
  EFECTIVO
  TRANSFERENCIA
  TARJETA
}

model Pedido {
  id           String        @id @default(uuid())
  tipo         TipoPedido    @default(LOCAL)
  estado       EstadoPedido  @default(PENDIENTE)
  total        Float         @default(0)

  nombreCliente   String?
  apellidoCliente String?
  numeroCliente   String?
  metodoPago      MetodoPago?

  direccion            String?
  costoEnvio           Float         @default(0)
  motivoCancelacion    String?
  canceladoPor         Role?

  direccionLat         Float?
  direccionLng         Float?
  direccionFormateada  String?
  piso                 String?
  departamento         String?
  referencias          String?
  notasRepartidor      String?
  shippingZoneName String?
  shippingReason String?
  direccionPrecision String?

  repartidorId String?
  repartidor   User?         @relation("RepartidorPedidos", fields: [repartidorId], references: [id])

  detalles         PedidoDetalle[]
  ofertasAplicadas PedidoOferta[]
  movimientosCaja  CajaMovimiento[]
  createdAt        DateTime      @default(now())
}

model PedidoDetalle {
  id String @id @default(uuid())
  pedidoId String
  productoId String
  cantidad Int
  aderezos Aderezo[]

  precioUnitario Float @default(0)
  sinExtras Boolean @default(false)

  extras Json?

  subtotal Float
  notas String?

  pedido Pedido @relation(fields: [pedidoId], references: [id])
  producto Producto @relation(fields: [productoId], references: [id])
  ofertaAplicada PedidoOferta[]
}

// --- GESTIÓN DE EXTRAS ---

model Extra {
  id               String   @id @default(uuid())
  nombre           String   @unique
  precio           Float    @default(500)
  unidadMedida     String   @default("un")
  stockActual      Float    @default(0)
  activo           Boolean  @default(true)
  categoria        String   @default("ADEREZOS")

  insumoId         String?
  insumo           Insumo?  @relation(fields: [insumoId], references: [id])

  preciosPorCategoria ExtraPrecio[]
  categoriasAplica    ExtraCategoria[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ExtraCategoria {
  id         String @id @default(uuid())
  extraId    String
  categoriaId String

  extra     Extra     @relation(fields: [extraId], references: [id], onDelete: Cascade)
  categoria Categoria @relation(fields: [categoriaId], references: [id], onDelete: Cascade)

  @@unique([extraId, categoriaId])
}

model ExtraPrecio {
  id          String @id @default(uuid())
  extraId     String
  categoriaId String
  precio      Float @default(0)

  extra     Extra     @relation(fields: [extraId], references: [id], onDelete: Cascade)
  categoria Categoria @relation(fields: [categoriaId], references: [id], onDelete: Cascade)

  @@unique([extraId, categoriaId])
}

model Aderezo {
  id               String   @id @default(uuid())
  nombre           String   @unique
  stockActual      Float    @default(0)
  activo           Boolean  @default(true)

  precioPorCategoria  AderezoPrecio[]
  categoriasAplica    AderezoCategoria[]
  detalles            PedidoDetalle[]
}

model AderezoCategoria {
  id          String @id @default(uuid())
  aderezoId   String
  categoriaId String

  aderezo   Aderezo   @relation(fields: [aderezoId], references: [id], onDelete: Cascade)
  categoria Categoria @relation(fields: [categoriaId], references: [id], onDelete: Cascade)

  @@unique([aderezoId, categoriaId])
}

// ============================================
// SISTEMA DE OFERTAS
// ============================================

enum TipoOferta {
  DOS_POR_UNO
  COMBO
  DESCUENTO_PORCENTAJE
  DESCUENTO_MONTO_FIJO
}

enum EstadoOferta {
  ACTIVA
  PAUSADA
  VENCIDA
}

model Oferta {
  id                  String          @id @default(uuid())
  nombre              String
  descripcion         String?
  tipo                TipoOferta
  estado              EstadoOferta    @default(ACTIVA)

  fechaInicio         DateTime
  fechaFin            DateTime?
  activa              Boolean         @default(true)

  porcentajeDescuento Float?
  montoDescuento      Float?

  maxUsosPorCliente   Int?
  maxUsosTotales      Int?
  usosActuales        Int             @default(0)

  diasAplicables      String          @default("1,2,3,4,5,6,7")
  horaInicio          String?
  horaFin             String?

  aplicaPorLinea      Boolean         @default(true)

  productos           OfertaProducto[]
  gruposCombo         GrupoCombo[]
  pedidosAplicados    PedidoOferta[]

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([activa, estado])
  @@index([fechaInicio, fechaFin])
}

model OfertaProducto {
  id            String    @id @default(uuid())
  ofertaId      String
  productoId    String
  obligatorio   Boolean   @default(false)
  cantidadMin   Int       @default(1)
  cantidadMax   Int?
  precioEspecial Float?

  oferta        Oferta    @relation(fields: [ofertaId], references: [id], onDelete: Cascade)
  producto      Producto  @relation(fields: [productoId], references: [id])

  @@unique([ofertaId, productoId])
}

model GrupoCombo {
  id            String        @id @default(uuid())
  ofertaId      String
  nombre        String
  obligatorio   Boolean       @default(true)
  cantidad      Int           @default(1)

  oferta        Oferta        @relation(fields: [ofertaId], references: [id], onDelete: Cascade)
  opciones      GrupoOpcion[]
}

model GrupoOpcion {
  id            String      @id @default(uuid())
  grupoComboId  String
  productoId    String

  grupoCombo    GrupoCombo  @relation(fields: [grupoComboId], references: [id], onDelete: Cascade)
  producto      Producto    @relation(fields: [productoId], references: [id])

  @@unique([grupoComboId, productoId])
}

model PedidoOferta {
  id String @id @default(uuid())
  pedidoId String
  ofertaId String
  pedidoDetalleId String? @unique

  precioOriginal Float
  precioFinal Float
  descuentoAplicado Float

  pedido Pedido @relation(fields: [pedidoId], references: [id])
  oferta Oferta @relation(fields: [ofertaId], references: [id])
  pedidoDetalle PedidoDetalle? @relation(fields: [pedidoDetalleId], references: [id])

  @@index([pedidoId])
  @@index([ofertaId])
}

model AderezoPrecio {
  id String @id @default(uuid())
  aderezoId String
  categoriaId String
  precio Float @default(0)

  aderezo Aderezo @relation(fields: [aderezoId], references: [id], onDelete: Cascade)
  categoria Categoria @relation(fields: [categoriaId], references: [id], onDelete: Cascade)

  @@unique([aderezoId, categoriaId])
}

enum TipoMovimientoCaja {
  ENTRADA
  SALIDA
  AJUSTE
}

model CajaMovimiento {
  id String @id @default(uuid())
  pedidoId String?
  tipo TipoMovimientoCaja
  montoTotal Float
  gananciaNegocio Float
  gananciaRepartidor Float
  descripcion String?
  confirmadoPor String?
  fechaConfirmacion DateTime?
  createdAt DateTime @default(now())

  pedido Pedido? @relation(fields: [pedidoId], references: [id])
}

// --- CONFIGURACIÓN DEL NEGOCIO ---

model Configuracion {
  id          String   @id @default(uuid())
  clave       String   @unique // Ej: "alias_transferencia", "whatsapp_numero"
  valor       String // Ej: "after.panch", "+5491123456789"
  descripcion String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// --- SISTEMA DE ENVÍOS ---

enum ShippingMode {
  RADIUS
  POLYGON
  RADIUS_TIERS
}

model ShippingConfig {
  id                   String       @id @default(uuid())
  mode                 ShippingMode @default(RADIUS)
  localLat             Float
  localLng             Float
  radiusKm             Float        @default(5)
  radiusPrice          Float        @default(0)
  maxDeliveryRadiusKm  Float        @default(10)
  borderToleranceMeters Int         @default(500)
  updatedAt            DateTime     @updatedAt
}

model ShippingZone {
  id        String   @id @default(uuid())
  name      String
  price     Float
  polygon   Json     // GeoJSON: { type: "Polygon", coordinates: [[[lng,lat],...]] }
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GeocodingCache {
  id String @id @default(uuid())
  normalizedKey String @unique
  formattedAddress String
  lat Float
  lng Float
  importance Float @default(1)
  precision String @default("exact")
  hitCount Int @default(1)
  createdAt DateTime @default(now())
  lastUsedAt DateTime @updatedAt

  @@index([normalizedKey])
}

model ShippingRadiusTier {
  id        String   @id @default(uuid())
  fromKm    Float
  toKm      Float
  price     Float
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}